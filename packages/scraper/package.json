{
  "name": "@scraper/scraper",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./crawl-run": {
      "types": "./dist/crawl-run.d.ts",
      "default": "./dist/crawl-run.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@scraper/db": "workspace:*",
    "@scraper/shared": "workspace:*",
    "cheerio": "^1.0.0",
    "crawlee": "^3.13.0",
    "ioredis": "^5.4.1",
    "playwright": "^1.48.2",
    "robots-parser": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
