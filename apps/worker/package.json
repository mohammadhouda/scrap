{
  "name": "@scraper/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "start": "node dist/index.js",
    "crawl": "dotenv -e ../../.env -- tsx src/scripts/enqueue-crawl.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@scraper/db": "workspace:*",
    "@scraper/processor": "workspace:*",
    "@scraper/rag": "workspace:*",
    "@scraper/scraper": "workspace:*",
    "@scraper/shared": "workspace:*",
    "bullmq": "^5.28.0",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
